--- !u!114 &433423221
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 433423219}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7b519fc5c42d7be489aa1a0dbbaa79a8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  speed: 3
  walkDistance: 3
  dialoguePanel: {fileID: 1089862263}
  nameText: {fileID: 1788553459}
  dialogueText: {fileID: 357952785}
  typingSpeed: 0.04
  typeSound: {fileID: 0}
  submarineTransform: {fileID: 1356482597}
  cameraPanSpeed: 3
  submarineViewDuration: 4
  partItemNames:
  - Part1
  - Part2
  - Part3
  - Part4
  introPhrases:
  - speaker: 0
    text: "\u0414\u043E\u0431\u0440\u044B\u0439 \u0434\u0435\u043D\u044C! \u0414\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u043C\u043E\u044E
      \u043B\u0430\u0432\u043A\u0443! \u0416\u0435\u043B\u0430\u0435\u0448\u044C
      \u043F\u0440\u0438\u043A\u0443\u043F\u0438\u0442\u044C \u0441\u0432\u0435\u0436\u0438\u0445...
      \u0430, \u0441\u0442\u043E\u043F."
  - speaker: 0
    text: "\u0422\u044C\u0444\u0443 \u0442\u044B, \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430.
      \u042F \u0436 \u0443\u0436\u0435 \u043B\u0435\u0442 \u0434\u0432\u0435\u0441\u0442\u0438
      \u043D\u0438\u0447\u0435\u043C \u043D\u0435 \u0442\u043E\u0440\u0433\u0443\u044E.
      \u0414\u0430 \u0438 \u043D\u0435\u043A\u043E\u043C\u0443."
  - speaker: 0
    text: "\u041F\u043E\u0433\u043E\u0434\u0438-\u043A\u0430... \u0422\u0430\u043A
      \u044D\u0442\u043E \u0442\u044B \u0441\u0435\u0439\u0447\u0430\u0441 \u0442\u0430\u043A
      \u0437\u043D\u0430\u0442\u043D\u043E \u0433\u0440\u043E\u043C\u044B\u0445\u043D\u0443\u043B
      \u043D\u0430 \u0432\u0441\u044E \u043E\u043A\u0440\u0443\u0433\u0443?"
  - speaker: 1
    text: "(\u0423\u0434\u0438\u0432\u043B\u0451\u043D\u043D\u043E \u0441\u043C\u043E\u0442\u0440\u0438\u0442
      \u043D\u0430 \u041B\u0430\u0432\u043E\u0447\u043D\u0438\u043A\u0430)"
  - speaker: 0
    text: "\u041C\u043E\u043B\u0447\u0438\u0448\u044C? \u041D\u0443, \u043B\u043E\u0433\u0438\u0447\u043D\u043E.
      \u041F\u043E\u0439\u0434\u0435\u043C-\u043A\u0430 \u0433\u043B\u044F\u043D\u0435\u043C,
      \u043E\u0431\u043E \u0447\u0442\u043E \u0442\u044B \u0442\u0430\u043C \u0432\u0440\u0435\u0437\u0430\u043B\u0441\u044F..."
  repairOfferPhrases:
  - speaker: 0
    text: "\u0414\u0430 \u0443\u0436... \u0422\u0432\u043E\u044F \u0436\u0435\u0441\u0442\u044F\u043D\u043A\u0430
      \u0437\u043D\u0430\u0442\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0430.
      \u0421\u0430\u043C\u0430 \u043E\u043D\u0430 \u043D\u0438\u043A\u0443\u0434\u0430
      \u043D\u0435 \u043F\u043E\u043F\u043B\u044B\u0432\u0435\u0442."
  - speaker: 1
    text: "(\u041C\u043E\u043B\u0447\u0430 \u0441\u043C\u043E\u0442\u0440\u0438\u0442
      \u043D\u0430 \u041B\u0430\u0432\u043E\u0447\u043D\u0438\u043A\u0430)"
  - speaker: 0
    text: "\u041D\u0435 \u0441\u043C\u043E\u0442\u0440\u0438 \u0442\u0430\u043A.
      \u041D\u0435 \u0431\u0443\u0434\u0443 \u0447\u0438\u043D\u0438\u0442\u044C"
  - speaker: 0
    text: "\u0425\u043E\u0442\u044F \u0440\u0443\u043A\u0438 \u043F\u043E\u043C\u043D\u044F\u0442!
      \u041B\u0430\u0434\u043D\u043E \u0443\u0436, \u043F\u043E\u0447\u0438\u043D\u044E.
      \u041D\u043E \u0437\u0430\u0440\u0430\u043D\u0435\u0435 \u0433\u043E\u0432\u043E\u0440\u044E,
      \u0437\u0430\u043F\u0447\u0430\u0441\u0442\u0435\u0439 \u043D\u0435\u0442"
  - speaker: 0
    text: "\u0412\u0441\u0435 \u043E\u043D\u0438 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C
      \u0432 \u0433\u043E\u0440\u043E\u0434\u0435. \u0410 \u0442\u0430\u043C, \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C,
      \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u043D\u0430\u0437\u0430\u0434
      \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430 \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u0430."
  - speaker: 0
    text: "\u0412\u0437\u0440\u044B\u0432 \u043D\u0430 \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
      \u0444\u0430\u0431\u0440\u0438\u043A\u0435. \u0418\u0437-\u0437\u0430 \u043D\u0430\u043F\u043B\u044B\u0432\u0430
      \u0440\u0430\u0434\u0438\u0430\u0446\u0438\u0438 \u0432\u0441\u0435 \u0436\u0438\u0442\u0435\u043B\u0438
      \u0441\u0442\u0430\u043B\u0438 \u043C\u0443\u0442\u0430\u043D\u0442\u0430\u043C\u0438
      \u0438 \u043E\u0437\u0432\u0435\u0440\u0435\u043B\u0438."
  - speaker: 0
    text: "\u0422\u0430\u043A \u0447\u0442\u043E \u0435\u0441\u043B\u0438 \u043F\u043E\u0439\u0434\u0435\u0448\u044C,
      \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435.
      \u041C\u043E\u0436\u0435\u0448\u044C \u043F\u043E\u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C
      \u043C\u0435\u043D\u044F, \u044F \u043F\u043E\u0434\u0441\u043A\u0430\u0436\u0443,
      \u043A\u0430\u043A \u0443\u0441\u0442\u0440\u043E\u0435\u043D \u044D\u0442\u043E\u0442
      \u0433\u043E\u0440\u043E\u0434!"
  tutorialPhrases:
  - speaker: 0
    text: "\u041A\u0430\u043A \u0442\u0443\u0442 \u0432\u044B\u0436\u0438\u0432\u0430\u0442\u044C?
      \u0421\u043B\u0443\u0448\u0430\u0439 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E."
  - speaker: 0
    text: "\u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445, \u0434\u0432\u0435\u0440\u0438.
      \u0416\u0435\u043B\u0435\u0437\u043D\u044B\u0435 \u0434\u0432\u0435\u0440\u0438
      \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u0440\u044B\u0447\u0430\u0433\u0430\u043C\u0438,
      \u043F\u0440\u043E\u0441\u0442\u043E \u0434\u0451\u0440\u043D\u0438 \u0441\u043E
      \u0432\u0441\u0435\u0439 \u0441\u0438\u043B\u044B \u0438 \u0436\u0435\u043B\u0435\u0437\u043E
      \u043E\u0442\u043A\u0440\u043E\u0435\u0442\u0441\u044F."
  - speaker: 0
    text: "\u0414\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u044B\u0435 \u0434\u0432\u0435\u0440\u0438
      \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u043A\u043B\u044E\u0447\u0430\u043C\u0438,
      \u0433\u0434\u0435-\u043D\u0438\u0431\u0443\u0434\u044C \u043E\u043D\u0438
      \u0438 \u043B\u0435\u0436\u0430\u0442. \u041D\u0430\u0439\u0434\u044F \u043A\u043B\u044E\u0447,
      \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E \u0437\u0430\u0441\u0443\u043D\u044C
      \u0435\u0433\u043E \u0432 \u0434\u0432\u0435\u0440\u044C."
  - speaker: 0
    text: "\u041E\u0431\u044B\u0447\u043D\u043E \u043C\u043E\u0439 \u043D\u0430\u0440\u043E\u0434
      \u0445\u0440\u0430\u043D\u0438\u043B \u043A\u043B\u044E\u0447\u0438 \u0432
      \u0441\u0443\u043D\u0434\u0443\u043A\u0430\u0445, \u043F\u043E\u0442\u043E\u043C\u0443
      \u0447\u0442\u043E \u0442\u0430\u043A \u0432\u0435\u0441\u0435\u043B\u0435\u0435.
      \u0422\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u0443\u0434\u0430 \u0431\u0443\u0434\u0435\u0442
      \u0445\u0440\u0430\u043D\u0438\u0442\u044C \u043A\u043B\u044E\u0447 \u043D\u0435
      \u0432 \u0441\u0443\u043D\u0434\u0443\u043A\u0435."
  - speaker: 0
    text: "\u0412\u043E-\u0432\u0442\u043E\u0440\u044B\u0445, \u043E\u0431\u0440\u0430\u0449\u0430\u0439
      \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043D\u0430 \u0438\u043D\u0442\u0435\u0440\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0435
      \u0448\u0442\u0443\u043A\u0438 - \u043E\u043D\u0438 \u0441\u043B\u0435\u0433\u043A\u0430
      \u0441\u0432\u0435\u0442\u044F\u0442\u0441\u044F, \u0435\u0441\u043B\u0438
      \u043A \u043D\u0438\u043C \u043F\u043E\u0434\u043E\u0439\u0442\u0438."
  - speaker: 0
    text: "\u041C\u043E\u0439 \u043D\u0430\u0440\u043E\u0434 \u0438\u0445 \u043A\u0440\u0430\u0441\u0438\u043B
      \u0431\u043B\u0451\u0441\u0442\u043A\u0430\u043C\u0438, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E
      \u0442\u0440\u043E\u0433\u0430\u0442\u044C. \u0422\u0430\u043C \u044F\u0449\u0438\u043A\u0438
      \u0432\u0441\u044F\u043A\u0438\u0435, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
      \u0438\u0445 \u0435\u0449\u0451 \u0438 \u0448\u0432\u044B\u0440\u044F\u0442\u044C
      \u043C\u043E\u0436\u043D\u043E \u0432 \u043A\u043E\u0433\u043E-\u0442\u043E."
  - speaker: 0
    text: "\u0412-\u0442\u0440\u0435\u0442\u044C\u0438\u0445, \u0438\u0437\u0431\u0435\u0433\u0430\u0439
      \u043B\u043E\u0432\u0443\u0448\u0435\u043A. \u041C\u043E\u0439 \u043D\u0430\u0440\u043E\u0434
      \u0438\u0445 \u043F\u043E \u043F\u0440\u0438\u043A\u043E\u043B\u0443 \u0440\u0430\u0441\u0441\u0442\u0430\u0432\u043B\u044F\u043B,
      \u0447\u0442\u043E\u0431\u044B \u0436\u0438\u0442\u044C \u0431\u044B\u043B\u043E
      \u0432\u0435\u0441\u0435\u043B\u0435\u0435. \u041B\u043E\u0432\u0443\u0448\u043A\u0438
      \u043C\u043E\u0433\u0443\u0442 \u0442\u0435\u0431\u044F \u0440\u0430\u043D\u0438\u0442\u044C!"
  - speaker: 0
    text: "\u041E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435 \u0443\u0436\u0435
      \u043D\u0435 \u043F\u043E\u043C\u043D\u044E. \u0414\u0430\u0432\u0430\u0439,
      \u0443\u0434\u0430\u0447\u0438 \u0442\u0435\u0431\u0435 \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445,
      \u043F\u043E\u0434\u043B\u043E\u0434\u043E\u0447\u043D\u0438\u043A!"
  idleNoPartsPhrases:
  - speaker: 0
    text: "\u042D\u0445, \u043A\u0430\u043A \u0436\u0435 \u0445\u043E\u0447\u0435\u0442\u0441\u044F
      \u043F\u0440\u043E\u0434\u0430\u0442\u044C \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
      \u043A\u043E\u043C\u0443-\u043D\u0438\u0431\u0443\u0434\u044C..."
  - speaker: 0
    text: "\u042F \u0437\u043D\u0430\u044E \u043A\u0443\u0447\u0443 \u0441\u0435\u043A\u0440\u0435\u0442\u043E\u0432
      \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0441\u0442\u0430, \u043D\u043E
      \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u043E \u0438\u0445 \u043D\u0435
      \u0440\u0430\u0437\u0434\u0430\u043C! \u0428\u0443\u0447\u0443, \u0440\u0430\u0437\u0434\u0430\u043C,
      \u043C\u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043A\u0443\u0447\u043D\u043E."
  - speaker: 0
    text: "\u041F\u043E\u0434\u0432\u043E\u0434\u043D\u044B\u0439 \u043C\u0438\u0440
      \u043A\u0440\u0430\u0441\u0438\u0432, \u0435\u0441\u043B\u0438 \u043D\u0435
      \u043E\u0431\u0440\u0430\u0449\u0430\u0442\u044C \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F
      \u043D\u0430 \u043C\u0443\u0442\u0430\u043D\u0442\u043E\u0432 \u0432\u043E\u043A\u0440\u0443\u0433."
  - speaker: 0
    text: "\u041D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
      F, \u0435\u0449\u0451 \u0440\u0430\u0437. \u042D\u0442\u043E \u0442\u0430\u043A
      \u0443\u0441\u043F\u043E\u043A\u0430\u0438\u0432\u0430\u0435\u0442."
  idleWithPartsPhrases:
  - speaker: 0
    text: "\u041E\u0433\u043E! \u042F \u0433\u043B\u044F\u0436\u0443, \u0442\u044B
      \u0443\u0436\u0435 \u0440\u0430\u0437\u0434\u043E\u0431\u044B\u043B \u043A\u0430\u043A\u0443\u044E-\u0442\u043E
      \u0436\u0435\u043B\u0435\u0437\u043A\u0443! \u041C\u043E\u043B\u043E\u0442\u043E\u043A!"
  - speaker: 0
    text: "\u0415\u0449\u0435 \u043D\u0435\u043C\u043D\u043E\u0433\u043E - \u0438
      \u043C\u044B \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043C \u044D\u0442\u0443
      \u0432\u0430\u043D\u043D\u0443 \u043F\u043B\u0430\u0432\u0430\u0442\u044C."
  finalPhrases:
  - speaker: 0
    text: "\u041D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E! \u0422\u044B
      \u0441\u043E\u0431\u0440\u0430\u043B \u0432\u0441\u0435 \u0437\u0430\u043F\u0447\u0430\u0441\u0442\u0438!
      \u0418 \u0442\u0430\u043A \u0431\u044B\u0441\u0442\u0440\u043E!"
  - speaker: 0
    text: "\u041D\u0443 \u0447\u0442\u043E, \u044E\u043D\u0433\u0430, \u043E\u0442\u0445\u043E\u0434\u0438
      \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443. \u0421\u0435\u0439\u0447\u0430\u0441
      \u0441\u0442\u0430\u0440\u044B\u0439 \u043C\u0430\u0441\u0442\u0435\u0440 \u043F\u043E\u043A\u0430\u0436\u0435\u0442
      \u043A\u043B\u0430\u0441\u0441. \u0421\u043C\u043E\u0442\u0440\u0438! \u0411\u0443\u0434\u0443
      \u0448\u0442\u043E\u043F\u0430\u0442\u044C \u0438 \u0441\u0432\u0435\u0440\u043B\u0438\u0442\u044C,
      \u0430 \u0442\u044B \u0444\u043E\u043D\u0430\u0440\u0438\u043A\u043E\u043C
      \u0441\u0432\u0435\u0442\u0438."
  hintPrefab: {fileID: 0}
