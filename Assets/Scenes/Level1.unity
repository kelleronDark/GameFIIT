  dialogueText: {fileID: 357952785}
  merchantPhrases:
  - "\u041F\u0440\u0438\u0432\u0435\u0442, \u043F\u0443\u0442\u043D\u0438\u043A!
    \u0415\u0441\u0442\u044C \u043F\u0430\u0440\u0430 \u0437\u043E\u043B\u043E\u0442\u044B\u0445?"
  - "\u0423 \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u0437\u0435\u043B\u044C\u044F,
    \u043A\u043B\u044E\u0447\u0438... \u0434\u0430\u0436\u0435 \u0441\u0435\u043A\u0440\u0435\u0442\u044B."
  - "\u041D\u043E \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0441\u043B\u0438 \u0442\u044B
    \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0448\u044C \u0434\u043E\u0432\u0435\u0440\u0438\u0435..."
  - "\u041D\u0430\u0436\u043C\u0438 F \u0435\u0449\u0451 \u0440\u0430\u0437 \u2014
    \u044F \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0443 \u0431\u043E\u043B\u044C\u0448\u0435."
  typingSpeed: 0.04
